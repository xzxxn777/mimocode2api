# MiMoCode2API — Free MiMo Auto Proxy
# Device fingerprint → JWT → OpenAI-compatible API
# No registration, no API key required

# === Optional API Key for proxy access ===
# API_KEY=your-proxy-key

# === Upstream ===
# MIMO_FREE_BASE_URL=https://api.xiaomimimo.com

# === Device Fingerprint ===
# Leave empty for auto-generation (SHA256 of hostname|platform|arch|cpu|user)
# MIMO_FINGERPRINT=custom-fingerprint

# === Debug ===
# MIMO2API_DEBUG=true

# === Hermes Provider Configuration ===
# Add to ~/.hermes/config.yaml:
#
# custom_providers:
#   - name: mimocode
#     base_url: http://127.0.0.1:10000/v1
#     api_key: ""  # no auth needed for proxy access
#     model: mimo/mimo-auto