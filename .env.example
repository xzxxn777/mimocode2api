# MiMoCode2API — Free MiMo Auto Proxy
# Device fingerprint → JWT → OpenAI-compatible API

# === API Key (required for proxy access) ===
# Leave empty to auto-generate on startup (printed in logs)
# API_KEY=sk-your-key-here

# === Upstream (default: free MiMo API) ===
# MIMO_FREE_BASE_URL=https://api.xiaomimimo.com

# === Device Fingerprint (leave empty for auto-detect) ===
# MIMO_FINGERPRINT=

# === Debug ===
# MIMO2API_DEBUG=false

# === Hermes Provider Configuration ===
# Add to ~/.hermes/config.yaml:
#
# custom_providers:
#   - name: mimocode
#     base_url: http://127.0.0.1:10000/v1
#     api_key: <api-key-from-logs>
#     model: mimo/mimo-auto